{
  "name": "@memo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply memo-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply memo-db --remote"
  },
  "dependencies": {
    "@memo/shared": "*",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.19.0"
  }
}
